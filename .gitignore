# ── Raw data (too large / provider terms prohibit redistribution) ────────────
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.txt
data/raw/berkeley_earth/
# Keep the download instructions
!data/raw/README_data.md

# ── Processed panel (regenerated by 01_data_build.py) ────────────────────────
data/processed/

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter checkpoints ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS / editor artefacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Model checkpoint files (large) ───────────────────────────────────────────
*.pt
*.pkl
*.joblib

# ── Temporary / intermediate outputs ─────────────────────────────────────────
results/figures/*.png
results/tables/*.csv
# Keep the directory structure
!results/figures/.gitkeep
!results/tables/.gitkeep
